# Woshmart — environment variables
# Names only, no real values. Never commit .env with actual secrets (docs/SETUP_GUIDE.md §4).
# Every environment (dev/staging/production) has its own isolated set — never shared.

# --- App ---
NODE_ENV=
PORT=

# --- Twilio (WhatsApp Business API) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=

# --- Database (Postgres via Prisma) ---
DATABASE_URL=

# --- Redis (BullMQ) ---
REDIS_URL=

# --- Admin API auth ---
JWT_SIGNING_SECRET=

# --- Error tracking ---
SENTRY_DSN=

# --- Object storage (only if receipt image storage is in scope — see docs/SECURITY.md §3.6) ---
OBJECT_STORAGE_ACCESS_KEY_ID=
OBJECT_STORAGE_SECRET_ACCESS_KEY=
OBJECT_STORAGE_BUCKET=
OBJECT_STORAGE_REGION=
