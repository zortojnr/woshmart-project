# Woshmart — environment variables
# Names only, no real values. Never commit .env with actual secrets (docs/SETUP_GUIDE.md §4).
# Every environment (dev/staging/production) has its own isolated set — never shared.

# --- App ---
NODE_ENV=
PORT=

# --- Twilio (WhatsApp Business API) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=

# --- Database (Postgres via Prisma) ---
DATABASE_URL=

# --- Redis (BullMQ) ---
REDIS_URL=

# --- Admin API auth ---
JWT_SIGNING_SECRET=

# --- Bank transfer details (PRD.md §10 "Bank transfer instructions" copy — real values,
# not placeholders; this is the account customers are told to pay into) ---
BANK_NAME=
BANK_ACCOUNT_NUMBER=

# --- Error tracking ---
SENTRY_DSN=

# --- Urgent-alert email (payment/data-integrity dead-letters only — see
# docs/BUILD_SCRIPT.md Phase 7 item 8). Set all five or leave all five blank. ---
ALERT_SMTP_HOST=
ALERT_SMTP_PORT=
ALERT_SMTP_USER=
ALERT_SMTP_PASSWORD=
ALERT_EMAIL_TO=

# --- Object storage (only if receipt image storage is in scope — see docs/SECURITY.md §3.6) ---
OBJECT_STORAGE_ACCESS_KEY_ID=
OBJECT_STORAGE_SECRET_ACCESS_KEY=
OBJECT_STORAGE_BUCKET=
OBJECT_STORAGE_REGION=
