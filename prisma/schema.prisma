// Woshmart — Prisma schema
// Source of truth for this schema is docs/DATABASE_SCHEMA.md — if they diverge, that
// document wins and this file needs updating, not the other way around.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String    @id @default(uuid())
  phoneNumber         String    @unique @map("phone_number")
  name                String?
  firstOrderAt        DateTime? @map("first_order_at")
  lastOrderAt         DateTime? @map("last_order_at")
  totalOrders         Int       @default(0) @map("total_orders")
  totalSpendKobo      BigInt    @default(0) @map("total_spend_kobo")
  referralSource      String?   @map("referral_source")
  accountStatus       String    @default("active") @map("account_status") // active | flagged | blocked
  prepaymentRequired  Boolean   @default(false) @map("prepayment_required")
  notes               String?
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  orders Order[]

  @@map("users")
}

model Session {
  id            String    @id @default(uuid())
  phoneNumber   String    @unique @map("phone_number")
  state         String
  context       Json      @default("{}")
  lastMessageAt DateTime  @default(now()) @map("last_message_at")
  expiresAt     DateTime? @map("expires_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@map("sessions")
}

model Woshman {
  id                     String   @id @default(uuid())
  name                   String
  phoneNumber            String   @unique @map("phone_number")
  availability           String   @default("available") // available | on_job | off_duty
  jobsToday              Int      @default(0) @map("jobs_today")
  jobsThisMonth          Int      @default(0) @map("jobs_this_month")
  pieceRateEarningsKobo  BigInt   @default(0) @map("piece_rate_earnings_kobo")
  retainerPaidThisMonth  Boolean  @default(false) @map("retainer_paid_this_month")
  complaintsThisMonth    Int      @default(0) @map("complaints_this_month")
  missingItemsThisMonth  Int      @default(0) @map("missing_items_this_month")
  active                 Boolean  @default(true)
  joinedAt               DateTime @default(now()) @map("joined_at")

  orders Order[]

  @@map("woshmen")
}

model Partner {
  id                     String  @id @default(uuid())
  name                   String
  address                String?
  contactName            String? @map("contact_name")
  phoneNumber            String  @unique @map("phone_number")
  capacityPerDay         Int?    @map("capacity_per_day")
  canDoStarch            Boolean @default(false) @map("can_do_starch")
  canDoExpress           Boolean @default(false) @map("can_do_express")
  lastRating             Decimal? @db.Decimal(2, 1) @map("last_rating")
  status                 String  @default("active") // active | warning | suspended
  outstandingBalanceKobo BigInt  @default(0) @map("outstanding_balance_kobo")

  orders Order[]

  @@map("partners")
}

model Order {
  id                  String    @id @default(uuid())
  orderNumber         String    @unique @map("order_number")
  userId              String    @map("user_id")
  address             String
  landmark            String?
  zone                String
  serviceType         String    @map("service_type") // starter | weekly | family | household | per_item
  itemsDescription    String?   @map("items_description")
  serviceTotalKobo    BigInt    @map("service_total_kobo")
  smallBasketFeeKobo  BigInt    @default(0) @map("small_basket_fee_kobo")
  logisticsFeeKobo    BigInt    @default(0) @map("logistics_fee_kobo")
  grandTotalKobo      BigInt    @map("grand_total_kobo")
  amountPaidKobo      BigInt    @default(0) @map("amount_paid_kobo")
  paymentMethod       String    @map("payment_method") // transfer | cod
  paymentStatus       String    @default("pending") @map("payment_status") // pending | confirmed | refunded
  pickupDate          DateTime? @db.Date @map("pickup_date")
  pickupWindow        String?   @map("pickup_window")
  woshmanId           String?   @map("woshman_id")
  partnerId           String?   @map("partner_id")
  status              String    @default("initiated")
  // initiated | awaiting_confirmation | awaiting_payment | paid | assigned |
  // pickup_scheduled | picked_up | at_laundry | ready_for_delivery |
  // out_for_delivery | delivered | closed | cancelled | abandoned | disputed
  deliveredAt         DateTime? @map("delivered_at")
  notes               String?
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  user          User                 @relation(fields: [userId], references: [id])
  woshman       Woshman?             @relation(fields: [woshmanId], references: [id])
  partner       Partner?             @relation(fields: [partnerId], references: [id])
  statusHistory OrderStatusHistory[]
  messages      Message[]
  feedback      Feedback[]

  @@index([userId])
  @@index([status])
  @@index([woshmanId])
  @@index([createdAt])
  @@index([status, createdAt])
  @@map("orders")
}

model OrderStatusHistory {
  id         String   @id @default(uuid())
  orderId    String   @map("order_id")
  fromStatus String?  @map("from_status")
  toStatus   String   @map("to_status")
  changedBy  String   @map("changed_by") // system | admin:<id> | woshman | partner
  note       String?
  createdAt  DateTime @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@map("order_status_history")
}

model Message {
  id         String   @id @default(uuid())
  twilioSid  String?  @unique @map("twilio_sid")
  direction  String   // inbound | outbound
  phoneNumber String  @map("phone_number")
  orderId    String?  @map("order_id")
  body       String?
  status     String?  // queued | sent | delivered | read | failed
  rawPayload Json?    @map("raw_payload")
  createdAt  DateTime @default(now()) @map("created_at")

  order Order? @relation(fields: [orderId], references: [id])

  @@index([phoneNumber])
  @@index([orderId])
  @@index([twilioSid])
  @@map("messages")
}

model Feedback {
  id        String   @id @default(uuid())
  orderId   String   @map("order_id")
  score     Int      // 1-3
  text      String?
  resolved  String   @default("n/a") // yes | no | n/a
  cooNotes  String?  @map("coo_notes")
  createdAt DateTime @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id])

  @@map("feedback")
}

model Admin {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String    @map("password_hash")
  name         String
  role         String    @default("ops") // super_admin | ops | viewer
  active       Boolean   @default(true)
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  actions       AdminAction[]
  pricingEdits  PricingConfig[]

  @@map("admins")
}

model AdminAction {
  id          String   @id @default(uuid())
  adminId     String   @map("admin_id")
  action      String
  entityType  String   @map("entity_type")
  entityId    String?  @map("entity_id")
  beforeValue Json?    @map("before_value")
  afterValue  Json?    @map("after_value")
  ipAddress   String?  @map("ip_address")
  createdAt   DateTime @default(now()) @map("created_at")

  admin Admin @relation(fields: [adminId], references: [id])

  @@map("admin_actions")
}

model PricingConfig {
  key       String   @id
  value     Json
  updatedBy String?  @map("updated_by")
  updatedAt DateTime @updatedAt @map("updated_at")

  admin Admin? @relation(fields: [updatedBy], references: [id])

  @@map("pricing_config")
}
