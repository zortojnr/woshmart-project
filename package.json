{
  "name": "woshmart-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Woshmart — WhatsApp-based laundry ordering and operations backend",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.0.0"
  },
  "type": "commonjs",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src tests scripts --max-warnings 0",
    "lint:fix": "eslint src tests scripts --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "seed:super-admin": "tsx scripts/seed-super-admin.ts",
    "seed:test-order": "tsx scripts/seed-test-order.ts",
    "seed:test-woshman-partner": "tsx scripts/seed-test-woshman-partner.ts",
    "delete:test-woshman-partner": "tsx scripts/delete-test-woshman-partner.ts"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "@sentry/node": "10.67.0",
    "bcryptjs": "3.0.3",
    "bullmq": "5.80.9",
    "dotenv": "17.4.2",
    "express": "4.22.2",
    "ioredis": "5.11.1",
    "jsonwebtoken": "9.0.3",
    "nodemailer": "9.0.3",
    "pino": "9.14.0",
    "pino-http": "10.5.0",
    "twilio": "5.13.1",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "2.4.6",
    "@types/express": "4.17.25",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "20.19.43",
    "@types/nodemailer": "8.0.1",
    "@types/supertest": "6.0.3",
    "@typescript-eslint/eslint-plugin": "8.64.0",
    "@typescript-eslint/parser": "8.64.0",
    "eslint": "8.57.1",
    "eslint-config-prettier": "9.1.2",
    "prettier": "3.9.5",
    "prisma": "5.22.0",
    "supertest": "7.2.2",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "vitest": "2.1.9"
  }
}
